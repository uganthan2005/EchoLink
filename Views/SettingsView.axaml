<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EchoLink.ViewModels"
             xmlns:m="using:EchoLink.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="800"
             x:Class="EchoLink.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="Transparent">

    <ScrollViewer>
        <DockPanel Margin="32,24" LastChildFill="False">

            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,24">
                <TextBlock Text="Settings"
                           FontSize="28" FontWeight="Bold" Foreground="#FFFFFF"/>
                <TextBlock Text="Configure EchoLink features, sync behaviour, and keyboard shortcuts"
                           FontSize="13" Foreground="#B3B3B3"/>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════════
                 Section 1: EchoBoard™ — Clipboard Sync Engine
            ════════════════════════════════════════════════════════════ -->
            <Border DockPanel.Dock="Top" Classes="Card" Margin="0,0,0,20">
                <StackPanel Spacing="18">
                    <!-- Section title -->
                    <StackPanel Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="📋" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="EchoBoard™" FontSize="18" FontWeight="Bold"
                                       Foreground="#00E5FF"/>
                        </StackPanel>
                        <TextBlock Text="Clipboard synchronisation engine across your mesh network"
                                   FontSize="12" Foreground="#B3B3B3" Margin="30,0,0,0"/>
                    </StackPanel>

                    <Border Height="1" Background="#3A3A3A" Margin="0,2"/>

                    <!-- MirrorClip -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="MirrorClip — Live Sync" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#FFFFFF"/>
                            <TextBlock Text="Automatically mirror your clipboard across all connected devices in real-time. Copy on one, paste on any."
                                       FontSize="12" Foreground="#B3B3B3" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding MirrorClipEnabled}"
                                      OnContent="ON" OffContent="OFF"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <!-- GhostPaste -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="GhostPaste — Silent Remote Paste" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#FFFFFF"/>
                            <TextBlock Text="Silently paste incoming clipboard entries without popup notifications. Content appears instantly in your clipboard."
                                       FontSize="12" Foreground="#B3B3B3" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding GhostPasteEnabled}"
                                      OnContent="ON" OffContent="OFF"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <!-- SnapShare -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="SnapShare — Quick Broadcast" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#FFFFFF"/>
                            <TextBlock Text="One-click broadcast your current clipboard to all online peers. Perfect for sharing links, code snippets, and passwords."
                                       FontSize="12" Foreground="#B3B3B3" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding SnapShareEnabled}"
                                      OnContent="ON" OffContent="OFF"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <!-- History limit -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Clipboard Vault Size" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#FFFFFF"/>
                            <TextBlock Text="Maximum number of clipboard entries to keep in history before oldest entries are auto-purged."
                                       FontSize="12" Foreground="#B3B3B3" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding ClipboardHistoryLimit}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#00E5FF" VerticalAlignment="Center"/>
                            <Slider Value="{Binding ClipboardHistoryLimit}"
                                    Minimum="10" Maximum="200"
                                    Width="140"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Clipboard target devices -->
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                            <TextBlock Grid.Column="0"
                                       Text="Clipboard Share Targets"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="All"
                                    Command="{Binding SelectAllClipboardDevicesCommand}"
                                    Background="Transparent"
                                    Foreground="#00E5FF"
                                    Padding="8,4"/>
                            <Button Grid.Column="2"
                                    Content="None"
                                    Command="{Binding SelectNoneClipboardDevicesCommand}"
                                    Background="Transparent"
                                    Foreground="#FFB74D"
                                    Padding="8,4"/>
                            <Button Grid.Column="3"
                                    Content="Refresh"
                                    Command="{Binding RefreshClipboardDevicesCommand}"
                                    Background="Transparent"
                                    Foreground="#3273F6"
                                    Padding="8,4"/>
                        </Grid>

                        <TextBlock Text="Select which devices receive MirrorClip and SnapShare updates."
                                   FontSize="12"
                                   Foreground="#B3B3B3"
                                   TextWrapping="Wrap"/>

                        <ItemsControl ItemsSource="{Binding ClipboardShareDevices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="m:ClipboardShareDevice">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2,0,2">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Name}" Foreground="#FFFFFF"/>
                                            <TextBlock Text="{Binding IpAddress}"
                                                       Foreground="#B3B3B3"
                                                       FontSize="11"
                                                       FontFamily="Consolas, monospace"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding OnlineLabel}"
                                                   FontSize="11"
                                                   Foreground="#B3B3B3"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
                 Section 2: Hotkeys — Command Shortcuts
            ════════════════════════════════════════════════════════════ -->
            <Border DockPanel.Dock="Top" Classes="Card" Margin="0,0,0,20">
                <StackPanel Spacing="18">
                    <StackPanel Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⌨️" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Hotkeys" FontSize="18" FontWeight="Bold"
                                       Foreground="#00E5FF"/>
                        </StackPanel>
                        <TextBlock Text="Keyboard shortcuts for rapid actions — click a shortcut field to rebind"
                                   FontSize="12" Foreground="#B3B3B3" Margin="30,0,0,0"/>
                    </StackPanel>

                    <Border Height="1" Background="#3A3A3A" Margin="0,2"/>

                    <!-- Hotkey list -->
                    <ItemsControl ItemsSource="{Binding Hotkeys}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="m:HotkeyBinding">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,10">
                                    <!-- Enable toggle -->
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsEnabled}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0"/>

                                    <!-- Label -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DisplayName}"
                                               FontSize="13" Foreground="#FFFFFF"
                                               VerticalAlignment="Center"/>

                                    <!-- Hotkey badge -->
                                    <Border Grid.Column="2"
                                            Background="#1E1E1E"
                                            CornerRadius="6"
                                            Padding="12,6"
                                            Margin="8,0"
                                            MinWidth="120">
                                        <TextBox Text="{Binding KeyGesture}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="#00E5FF"
                                                 FontSize="13"
                                                 FontWeight="SemiBold"
                                                 TextAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 IsReadOnly="True"
                                                 Tag="{Binding}"
                                                 KeyDown="HotkeyTextBox_KeyDown"
                                                 GotFocus="HotkeyTextBox_GotFocus"
                                                 LostFocus="HotkeyTextBox_LostFocus"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
                 Section 3: General
            ════════════════════════════════════════════════════════════ -->
            <Border DockPanel.Dock="Top" Classes="Card" Margin="0,0,0,24">
                <StackPanel Spacing="18">
                    <StackPanel Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⚙️" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="General" FontSize="18" FontWeight="Bold"
                                       Foreground="#00E5FF"/>
                        </StackPanel>
                        <TextBlock Text="Application behaviour and system integration"
                                   FontSize="12" Foreground="#B3B3B3" Margin="30,0,0,0"/>
                    </StackPanel>

                    <Border Height="1" Background="#3A3A3A" Margin="0,2"/>

                    <!-- Launch on startup -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Launch on Startup" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#FFFFFF"/>
                            <TextBlock Text="Automatically start EchoLink when you log in to your computer."
                                       FontSize="12" Foreground="#B3B3B3" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding LaunchOnStartup}"
                                      OnContent="ON" OffContent="OFF"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Minimize to tray -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Minimize to Tray" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#FFFFFF"/>
                            <TextBlock Text="Keep EchoLink running in the system tray when you close the window."
                                       FontSize="12" Foreground="#B3B3B3" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding MinimizeToTray}"
                                      OnContent="ON" OffContent="OFF"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Notifications -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Notifications" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#FFFFFF"/>
                            <TextBlock Text="Show desktop notifications for incoming clipboard entries, file transfers, and pairing requests."
                                       FontSize="12" Foreground="#B3B3B3" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowNotifications}"
                                      OnContent="ON" OffContent="OFF"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
                 Action buttons
            ════════════════════════════════════════════════════════════ -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,16">
                <!-- Status -->
                <Border Grid.Column="0"
                        Background="#1A3A2A" CornerRadius="6" Padding="12,6"
                        IsVisible="{Binding ShowSaved}">
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12" Foreground="#00E676"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Reset -->
                <Button Grid.Column="2"
                        Background="Transparent"
                        Foreground="#FF5252"
                        CornerRadius="8"
                        Padding="16,10"
                        Content="Reset to Defaults"
                        Command="{Binding ResetToDefaultsCommand}"
                        Margin="0,0,12,0"/>

                <!-- Save -->
                <Button Grid.Column="3"
                        Classes="Primary"
                        Content="💾  Save Settings"
                        Command="{Binding SaveSettingsCommand}"/>
            </Grid>

        </DockPanel>
    </ScrollViewer>
</UserControl>
