<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EchoLink.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="720"
        x:Class="EchoLink.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="EchoLink"
        MinWidth="900" MinHeight="600"
        Background="#121212"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        TransparencyLevelHint="AcrylicBlur"
        xmlns:conv="using:EchoLink.Converters">

    <Window.Resources>
        <conv:BoolToColorConverter x:Key="SshStatusColor" TrueColor="#00E676" FalseColor="#FF5252"/>
    </Window.Resources>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- Root grid: full window -->
    <Grid ColumnDefinitions="Auto,*">

        <!-- ══ LEFT SIDEBAR ══════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Width="240"
                Background="#1E1E1E"
                BorderBrush="#2D2D2D"
                BorderThickness="0,0,1,0"
                IsVisible="{Binding IsSidebarOpen}">
            <DockPanel>

                <!-- Logo / App Name -->
                <StackPanel DockPanel.Dock="Top" Margin="20,30,20,24" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Ellipse Width="10" Height="10"
                                 Fill="#00E676"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="EchoLink"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#FFFFFF"/>
                    </StackPanel>
                    <TextBlock Text="Mesh Network"
                               FontSize="11"
                               Foreground="#B3B3B3"
                               Margin="20,0,0,0"/>
                </StackPanel>

                <!-- Nav buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="12,0" Spacing="4">

                    <Button Classes="Nav"
                            Command="{Binding NavigateDashboardCommand}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="⬡" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard"   VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="Nav"
                            Command="{Binding NavigateFileTransferCommand}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="📁" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="File Transfer" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="Nav"
                            Command="{Binding NavigateClipboardCommand}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="📋" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Clipboard Hub" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="Nav"
                            Command="{Binding NavigateRemoteControlCommand}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="🖱" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Remote Control" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="Nav"
                            Command="{Binding NavigateDebugConsoleCommand}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="🐛" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Debug Console" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Bottom: SSH Status + Logout + Version -->
                <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,12" Spacing="8">
                    
                    <Border Background="#2D2D30" CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" 
                                     Fill="{Binding IsSshReady, Converter={StaticResource SshStatusColor}}" 
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="SSH Ready" IsVisible="{Binding IsSshReady}" Foreground="#E0E0E0" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="SSH Missing" IsVisible="{Binding !IsSshReady}" Foreground="#FF5252" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <Button Classes="Nav"
                            Command="{Binding LogoutCommand}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="🚪" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Logout" VerticalAlignment="Center"
                                       Foreground="#FF5252"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="v1.0 · FOSS Hack 2026"
                               FontSize="10"
                               Foreground="#4A4A4A"
                               Margin="8,0,0,8"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ══ RIGHT CONTENT ═════════════════════════════════════════════ -->
        <DockPanel Grid.Column="1">

            <!-- Top header bar -->
            <Border DockPanel.Dock="Top"
                    Background="#1E1E1E"
                    BorderBrush="#2D2D2D"
                    BorderThickness="0,0,0,1"
                    Padding="20,12">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- Hamburger -->
                    <Button Grid.Column="0"
                            Command="{Binding ToggleSidebarCommand}"
                            Background="Transparent"
                            Foreground="#B3B3B3"
                            Padding="8,4"
                            CornerRadius="6"
                            Content="☰"
                            FontSize="18"/>

                    <!-- Page title -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding CurrentPageTitle}"
                               FontSize="17" FontWeight="SemiBold"
                               Foreground="#FFFFFF"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"/>
                </Grid>
            </Border>

            <!-- Animated page content -->
            <TransitioningContentControl
                DockPanel.Dock="Top"
                Content="{Binding CurrentPage}"
                Margin="0"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                PageTransition="{x:Null}"/>

        </DockPanel>

        <!-- Ssh Installation Overlay -->
        <Border Grid.Column="0" Grid.ColumnSpan="2"
                Background="#99000000"
                IsVisible="{Binding IsSshInstalling}"
                ZIndex="100">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Foreground="#3273F6" Width="200" Height="4" Margin="0,0,0,20"/>
                <TextBlock Text="{Binding SshStatusText}" FontSize="18" Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Pairing Request Notification Dialog Overlay -->
        <Border Grid.Column="0" Grid.ColumnSpan="2"
                Background="#99000000"
                IsVisible="{Binding ShowPairingRequest}"
                ZIndex="101">
            <Border Background="#252526" CornerRadius="8" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500" BorderBrush="#3E3E42" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Pairing Request" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                    <TextBlock Text="{Binding PairingRequestText}" FontSize="16" Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,25"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <Button Content="Reject" Command="{Binding RejectPairingCommand}" Background="#3A3A3C" Foreground="White" Padding="20,8" CornerRadius="4"/>
                        <Button Content="Accept" Command="{Binding AcceptPairingCommand}" Background="#0078D4" Foreground="White" Padding="20,8" CornerRadius="4"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</Window>
