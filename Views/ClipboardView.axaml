<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EchoLink.ViewModels"
             xmlns:m="using:EchoLink.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="680"
             x:Class="EchoLink.Views.ClipboardView"
             x:DataType="vm:ClipboardViewModel"
             Background="Transparent">

    <DockPanel Margin="32,24">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,20">
            <TextBlock Text="Clipboard Hub"
                       FontSize="28" FontWeight="Bold" Foreground="#FFFFFF"/>
            <TextBlock Text="Sync clipboard entries across selected mesh devices"
                       FontSize="13" Foreground="#B3B3B3"/>
        </StackPanel>

        <!-- Controls card -->
        <Border DockPanel.Dock="Top" Classes="Card" Margin="0,0,0,20">
            <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
                <!-- Auto-sync toggle -->
                <StackPanel Grid.Column="0" Grid.Row="0"
                            Orientation="Horizontal" Spacing="12"
                            VerticalAlignment="Center">
                    <ToggleSwitch IsChecked="{Binding IsAutoSyncEnabled}"
                                  OnContent="MirrorClip ON"
                                  OffContent="MirrorClip OFF"
                                  Foreground="#FFFFFF"/>
                </StackPanel>

                <!-- Status text -->
                <TextBlock Grid.Column="1" Grid.Row="0"
                           Text="{Binding StatusText}"
                           FontSize="12" Foreground="#B3B3B3"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>

                <!-- Push button -->
                <Button Grid.Column="2" Grid.Row="0"
                        Classes="Primary"
                        Content="⚡ SnapShare"
                        Command="{Binding PushClipboardCommand}"
                        VerticalAlignment="Center"/>

                <!-- Feature status badges -->
                <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1"
                            Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                    <Border Background="#1A2A30" CornerRadius="12" Padding="10,4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="7" Height="7"
                                     Fill="{Binding IsMirrorClipActive, Converter={StaticResource BoolToColor}}"/>
                            <TextBlock Text="MirrorClip" FontSize="11" Foreground="#B3B3B3"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1A2A30" CornerRadius="12" Padding="10,4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="7" Height="7"
                                     Fill="{Binding IsGhostPasteActive, Converter={StaticResource BoolToColor}}"/>
                            <TextBlock Text="GhostPaste" FontSize="11" Foreground="#B3B3B3"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1A2A30" CornerRadius="12" Padding="10,4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="7" Height="7"
                                     Fill="{Binding IsSnapShareActive, Converter={StaticResource BoolToColor}}"/>
                            <TextBlock Text="SnapShare" FontSize="11" Foreground="#B3B3B3"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Share targets card -->
        <Border DockPanel.Dock="Top" Classes="Card" Margin="0,0,0,16">
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                    <TextBlock Grid.Column="0"
                               Text="Clipboard Share Targets"
                               FontSize="13"
                               Foreground="#B3B3B3"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="All"
                            Command="{Binding SelectAllShareDevicesCommand}"
                            Padding="10,4"
                            Background="Transparent"
                            Foreground="#00E5FF"/>
                    <Button Grid.Column="2"
                            Content="None"
                            Command="{Binding SelectNoneShareDevicesCommand}"
                            Padding="10,4"
                            Background="Transparent"
                            Foreground="#FFB74D"/>
                    <Button Grid.Column="3"
                            Content="Refresh"
                            Command="{Binding RefreshShareDevicesCommand}"
                            Padding="10,4"
                            Background="Transparent"
                            Foreground="#3273F6"/>
                </Grid>

                <TextBlock Text="Only selected devices receive SnapShare and MirrorClip updates."
                           FontSize="11"
                           Foreground="#888888"/>

                <ItemsControl ItemsSource="{Binding ShareDevices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="m:ClipboardShareDevice">
                            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2,0,2">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsSelected}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Name}" Foreground="#FFFFFF"/>
                                    <TextBlock Text="{Binding IpAddress}"
                                               Foreground="#B3B3B3"
                                               FontSize="11"
                                               FontFamily="Consolas, monospace"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding OnlineLabel}"
                                           Foreground="#B3B3B3"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Actions row -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Spacing="12"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,12">
            <Button Background="Transparent"
                    Foreground="#FF5252"
                    CornerRadius="6"
                    Padding="10,6"
                    Content="Clear History"
                    Command="{Binding ClearHistoryCommand}"/>
        </StackPanel>

        <!-- Clipboard history feed -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding History}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="m:ClipboardEntry">
                        <!-- Chat-bubble style card -->
                        <Border Background="#2D2D2D"
                                CornerRadius="10"
                                Padding="16,12"
                                Margin="0,0,0,10"
                                MaxWidth="700"
                                HorizontalAlignment="Left">
                            <Grid RowDefinitions="Auto,Auto,Auto">

                                <!-- Snippet (trimmed) -->
                                <TextBlock Grid.Row="0"
                                           Text="{Binding Preview}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="Wrap"
                                           MaxLines="3"
                                           FontSize="13"
                                           Foreground="#FFFFFF"/>

                                <!-- Meta row: source device + time -->
                                <StackPanel Grid.Row="1"
                                            Orientation="Horizontal" Spacing="8"
                                            Margin="0,6,0,0">
                                    <TextBlock Text="📱"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SourceDevice}"
                                               FontSize="11" Foreground="#B3B3B3"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="·"
                                               FontSize="11" Foreground="#4A4A4A"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TimeAgo}"
                                               FontSize="11" Foreground="#4A4A4A"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Copy button -->
                                <Button Grid.Row="2"
                                        Background="Transparent"
                                        Foreground="#00E5FF"
                                        CornerRadius="4"
                                        Padding="0,4"
                                        FontSize="12"
                                        Content="⎘ Copy to clipboard"
                                        HorizontalAlignment="Left"
                                        Margin="0,6,0,0"
                                        Command="{Binding $parent[UserControl].((vm:ClipboardViewModel)DataContext).CopyEntryCommand}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</UserControl>
